# Local API server
PORT=3000
DATA_DIR=./data

# Frontend API target used after Cloudflare Pages deployment.
# Set public/config.json railwayUrl to your deployed Railway API URL.
RAILWAY_URL=https://your-api.up.railway.app

# Cloudflare direct deploy credentials.
# Do not commit real values. Use these as shell environment variables:
# export CLOUDFLARE_ACCOUNT_ID=...
# export CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROJECT_NAME=pcr-oc-2026jun
